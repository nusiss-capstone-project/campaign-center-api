{
  "info": {
    "_postman_id": "a1b2c3d4-campaign-center-api",
    "name": "Campaign Center API",
    "description": "Phase1 HTTP API. Set `baseUrl` (e.g. http://localhost:8080). Admin routes: `/campaign-center-api/v1/admin/...`. Web routes: `/campaign-center-api/v1/web/...`. OpenAI: set env `CAMPAIGN_CENTER_OPENAI_API_KEY` or `openai.api_key` in config.yml for translation generate.\n\n```bash\nBASE=http://localhost:8080/campaign-center-api/v1\n```",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "campaignId", "value": "1001" },
    { "key": "landingPageId", "value": "2001" },
    { "key": "userId", "value": "1001" }
  ],
  "item": [
    {
      "name": "Health & demo",
      "item": [
        {
          "name": "Ping",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/campaign-center-api/v1/ping",
            "description": "```bash\ncurl -sS '{{baseUrl}}/campaign-center-api/v1/ping'\n```"
          }
        }
      ]
    },
    {
      "name": "Admin — Campaigns",
      "item": [
        {
          "name": "Create campaign",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New User Top-up Reward Campaign\",\n  \"type\": \"TOPUP_REWARD\",\n  \"targetMarket\": \"US\",\n  \"registrationStartTime\": \"2026-05-15T00:00:00+08:00\",\n  \"registrationEndTime\": \"2026-05-20T23:59:59+08:00\",\n  \"campaignStartTime\": \"2026-05-15T00:00:00+08:00\",\n  \"campaignEndTime\": \"2026-05-31T23:59:59+08:00\",\n  \"targetUserSegment\": \"NEW_USER\",\n  \"rewardRules\": {\n    \"topupThreshold\": 100,\n    \"rewardAmount\": 10,\n    \"rewardType\": \"BONUS_CREDIT\",\n    \"maxClaimPerUser\": 1\n  },\n  \"landingPageId\": 0\n}\n",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/campaign-center-api/v1/admin/campaigns",
            "description": "```bash\ncurl -sS -X POST '{{baseUrl}}/campaign-center-api/v1/admin/campaigns' -H 'Content-Type: application/json' -d @body.json\n```"
          }
        },
        {
          "name": "List campaigns",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/campaign-center-api/v1/admin/campaigns?page=1&pageSize=10&status=2&type=TOPUP_REWARD",
              "host": ["{{baseUrl}}"],
              "path": ["campaign-center-api", "v1", "admin", "campaigns"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "10" },
                { "key": "status", "value": "2" },
                { "key": "type", "value": "TOPUP_REWARD" }
              ]
            }
          }
        },
        {
          "name": "Get campaign detail",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/campaign-center-api/v1/admin/campaigns/{{campaignId}}"
          }
        },
        {
          "name": "Update campaign (draft only)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New User Top-up Reward Campaign\",\n  \"targetMarket\": \"US\",\n  \"registrationStartTime\": \"2026-05-15T00:00:00+08:00\",\n  \"registrationEndTime\": \"2026-05-20T23:59:59+08:00\",\n  \"campaignStartTime\": \"2026-05-15T00:00:00+08:00\",\n  \"campaignEndTime\": \"2026-05-31T23:59:59+08:00\",\n  \"targetUserSegment\": \"NEW_USER\",\n  \"rewardRules\": {\n    \"topupThreshold\": 100,\n    \"rewardAmount\": 10,\n    \"rewardType\": \"BONUS_CREDIT\",\n    \"maxClaimPerUser\": 1\n  },\n  \"landingPageId\": 2001\n}\n",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/campaign-center-api/v1/admin/campaigns/{{campaignId}}"
          }
        },
        {
          "name": "Publish campaign",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"operator\": \"admin\"\n}\n",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/campaign-center-api/v1/admin/campaigns/{{campaignId}}/publish"
          }
        },
        {
          "name": "Archive campaign",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"operator\": \"admin\"\n}\n",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/campaign-center-api/v1/admin/campaigns/{{campaignId}}/archive",
            "description": "Draft always. Published only when not in [campaignStartTime, campaignEndTime] (e.g. not started yet or already ended).\n```bash\ncurl -sS -X POST '{{baseUrl}}/campaign-center-api/v1/{{client}}/campaigns/{{campaignId}}/archive' \\\n  -H 'Content-Type: application/json' \\\n  -d '{\"operator\":\"admin\"}'\n```"
          }
        }
      ]
    },
    {
      "name": "Admin — Landing pages",
      "item": [
        {
          "name": "Create landing page",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"defaultLang\": \"en\",\n  \"bannerImageUrl\": \"https://example.com/banner.png\",\n  \"title\": \"Top up {{threshold}} and get {{reward}} bonus\",\n  \"description\": \"Join the campaign and complete your first top-up to receive the reward.\",\n  \"terms\": \"Each user can claim the reward once.\"\n}\n",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/campaign-center-api/v1/admin/landing-pages"
          }
        },
        {
          "name": "List landing pages",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/campaign-center-api/v1/admin/landing-pages?page=1&pageSize=10&status=1&defaultLang=en",
              "host": ["{{baseUrl}}"],
              "path": ["campaign-center-api", "v1", "admin", "landing-pages"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "10" },
                { "key": "status", "value": "1" },
                { "key": "defaultLang", "value": "en" }
              ]
            }
          }
        },
        {
          "name": "Get landing page detail (default lang)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/campaign-center-api/v1/admin/landing-pages/{{landingPageId}}"
          }
        },
        {
          "name": "Get landing page detail (?lang=ja)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/campaign-center-api/v1/admin/landing-pages/{{landingPageId}}?lang=ja",
              "host": ["{{baseUrl}}"],
              "path": ["campaign-center-api", "v1", "admin", "landing-pages", "{{landingPageId}}"],
              "query": [{ "key": "lang", "value": "ja" }]
            }
          }
        },
        {
          "name": "Get landing page locale detail (merged)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/campaign-center-api/v1/admin/landing-pages/{{landingPageId}}/detail/ja"
          }
        },
        {
          "name": "List translated locales",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/campaign-center-api/v1/admin/landing-pages/{{landingPageId}}/translations"
          }
        },
        {
          "name": "Generate translation (OpenAI)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sourceLang\": \"en\",\n  \"targetLang\": \"ja\",\n  \"title\": \"Top up {{amount}} to get reward\",\n  \"description\": \"Recharge now and receive {{reward_amount}} bonus\",\n  \"terms\": \"Reward will expire in {{days}} days\"\n}\n",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/campaign-center-api/v1/admin/landing-pages/{{landingPageId}}/translations/generate"
          }
        },
        {
          "name": "Upsert translation (PUT)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"{{amount}} をチャージして報酬を獲得\",\n  \"description\": \"今すぐチャージして {{reward_amount}} ボーナスを受け取る\",\n  \"terms\": \"報酬は {{days}} 日後に失効します\",\n  \"operator\": \"admin\"\n}\n",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/campaign-center-api/v1/admin/landing-pages/{{landingPageId}}/translations/ja"
          }
        },
        {
          "name": "Update landing page (draft only)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"defaultLang\": \"en\",\n  \"bannerImageUrl\": \"https://example.com/banner.png\",\n  \"title\": \"Top up {{threshold}} and get {{reward}} bonus\",\n  \"description\": \"Join the campaign and complete your first top-up to receive the reward.\",\n  \"terms\": \"Each user can claim the reward once.\"\n}\n",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/campaign-center-api/v1/admin/landing-pages/{{landingPageId}}"
          }
        },
        {
          "name": "Publish landing page",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"operator\": \"admin\"\n}\n",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/campaign-center-api/v1/admin/landing-pages/{{landingPageId}}/publish"
          }
        }
      ]
    },
    {
      "name": "User — Campaigns",
      "item": [
        {
          "name": "Get campaign landing page UI",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/campaign-center-api/v1/web/campaigns/{{campaignId}}/landing-page?userId={{userId}}&lang=en",
              "host": ["{{baseUrl}}"],
              "path": ["campaign-center-api", "v1", "web", "campaigns", "{{campaignId}}", "landing-page"],
              "query": [
                { "key": "userId", "value": "{{userId}}" },
                { "key": "lang", "value": "en" }
              ]
            }
          }
        },
        {
          "name": "Join campaign",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 1001\n}\n",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/campaign-center-api/v1/web/campaigns/{{campaignId}}/join"
          }
        },
        {
          "name": "Simulate top-up (reward path)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 1001,\n  \"amount\": 120\n}\n",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/campaign-center-api/v1/web/campaigns/{{campaignId}}/top-up"
          }
        },
        {
          "name": "Simulate top-up (below threshold — 4002)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 1001,\n  \"amount\": 50\n}\n",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/campaign-center-api/v1/web/campaigns/{{campaignId}}/top-up"
          }
        }
      ]
    }
  ]
}
