  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "client", "value": "customer" },
    { "key": "campaignId", "value": "1001" },
    { "key": "landingPageId", "value": "2001" },
    { "key": "userId", "value": "1001" }
  ],
  "item": [
    {
      "name": "Health & demo",
      "item": [
        {
          "name": "Ping",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/campaign-center-api/v1/ping",
            "description": "```bash\ncurl -sS '{{baseUrl}}/campaign-center-api/v1/ping'\n```"
          }
        },
