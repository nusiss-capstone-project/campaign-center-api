    {
      "name": "Admin — Campaigns",
      "item": [
        {
          "name": "Create campaign",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New User Top-up Reward Campaign\",\n  \"type\": \"TOPUP_REWARD\",\n  \"targetMarket\": \"US\",\n  \"registrationStartTime\": \"2026-05-15T00:00:00+08:00\",\n  \"registrationEndTime\": \"2026-05-20T23:59:59+08:00\",\n  \"campaignStartTime\": \"2026-05-15T00:00:00+08:00\",\n  \"campaignEndTime\": \"2026-05-31T23:59:59+08:00\",\n  \"targetUserSegment\": \"NEW_USER\",\n  \"rewardRules\": {\n    \"topupThreshold\": 100,\n    \"rewardAmount\": 10,\n    \"rewardType\": \"BONUS_CREDIT\",\n    \"maxClaimPerUser\": 1\n  },\n  \"landingPageId\": 0\n}\n",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/campaign-center-api/v1/{{client}}/campaigns",
            "description": "```bash\ncurl -sS -X POST '{{baseUrl}}/campaign-center-api/v1/{{client}}/campaigns' \\\n  -H 'Content-Type: application/json' \\\n  -d '{\"name\":\"New User Top-up Reward Campaign\",\"type\":\"TOPUP_REWARD\",\"targetMarket\":\"US\",\"registrationStartTime\":\"2026-05-15T00:00:00+08:00\",\"registrationEndTime\":\"2026-05-20T23:59:59+08:00\",\"campaignStartTime\":\"2026-05-15T00:00:00+08:00\",\"campaignEndTime\":\"2026-05-31T23:59:59+08:00\",\"targetUserSegment\":\"NEW_USER\",\"rewardRules\":{\"topupThreshold\":100,\"rewardAmount\":10,\"rewardType\":\"BONUS_CREDIT\",\"maxClaimPerUser\":1},\"landingPageId\":0}'\n```"
          }
        },
        {
          "name": "List campaigns",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/campaign-center-api/v1/{{client}}/campaigns?page=1&pageSize=10&status=2&type=TOPUP_REWARD",
              "host": ["{{baseUrl}}"],
              "path": ["campaign-center-api", "v1", "{{client}}", "admin", "campaigns"],
              "query": [
                { "key": "page", "value": "1" },
